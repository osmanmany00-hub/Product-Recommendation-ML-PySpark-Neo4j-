   "source": [
    "---\n",
    "## 9. Hybrid Recommendations\n",
    "<a id='9-hybrid'></a>\n",
    "\n",
    "Combines ALS (collaborative filtering) scores with graph-based scores using a weighted blend."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "hybrid-rec",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── ALS Recommendations for target user ──────\n",
    "als_recs_pd = recs_with_details.toPandas().rename(\n",
    "    columns={\"predicted_rating\": \"als_score\"}\n",
    ")\n",
    "\n",
    "# Normalize ALS scores to [0, 1]\n",
    "als_min = als_recs_pd['als_score'].min()\n",
    "als_max = als_recs_pd['als_score'].max()\n",
    "als_recs_pd['als_score_norm'] = (\n",
    "    (als_recs_pd['als_score'] - als_min) / (als_max - als_min + 1e-8)\n",
    ")\n",
    "\n",
    "# ─── Graph Scores (simulated if Neo4j offline) ─\n",
    "if results:\n",
    "    graph_scores_pd = pd.DataFrame(results)[\n",
    "        ['product_id', 'avg_rating']\n",
    "    ].rename(columns={'avg_rating': 'graph_score'})\n",
    "else:\n",
    "    # Simulate graph scores\n",
    "    graph_scores_pd = als_recs_pd[['product_id']].copy()\n",
    "    graph_scores_pd['graph_score'] = np.random.uniform(3.0, 5.0, len(graph_scores_pd))\n",
    "\n",
    "# Normalize graph scores\n",
    "g_min = graph_scores_pd['graph_score'].min()\n",
    "g_max = graph_scores_pd['graph_score'].max()\n",
    "graph_scores_pd['graph_score_norm'] = (\n",
    "    (graph_scores_pd['graph_score'] - g_min) / (g_max - g_min + 1e-8)\n",
    ")\n",
    "\n",
    "# ─── Weighted Blend ────────────────────────────\n",
    "ALS_WEIGHT   = 0.6\n",
    "GRAPH_WEIGHT = 0.4\n",
    "\n",
    "hybrid_df = als_recs_pd.merge(graph_scores_pd, on='product_id', how='left')\n",
    "hybrid_df['graph_score_norm'].fillna(0.5, inplace=True)\n",
    "\n",
    "hybrid_df['hybrid_score'] = (\n",
    "    ALS_WEIGHT   * hybrid_df['als_score_norm'] +\n",
    "    GRAPH_WEIGHT * hybrid_df['graph_score_norm']\n",
    ")\n",
    "\n",
    "hybrid_df = hybrid_df.sort_values('hybrid_score', ascending=False)\n",
    "\n",
    "print(f\"\\n🤖 Hybrid Recommendations for User {TARGET_USER}:\")\n",
    "print(hybrid_df[['product_id', 'product_name', 'category', 'brand',\n",
    "                  'price', 'als_score', 'hybrid_score']]\n",
    "      .head(10)\n",
    "      .to_string(index=False))"
   ]
  },

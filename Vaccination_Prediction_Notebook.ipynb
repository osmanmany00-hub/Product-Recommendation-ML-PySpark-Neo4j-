   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eda-category",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Products by Category ──────────────────────\n",
    "cat_counts = pd_products['category'].value_counts()\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "cat_counts.plot(kind='bar', color=sns.color_palette(\"Set2\", len(cat_counts)), edgecolor='white')\n",
    "plt.title('Product Count by Category', fontsize=13, fontweight='bold')\n",

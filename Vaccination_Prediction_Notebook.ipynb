    "---\n",
    "## 1. Environment Setup & Imports\n",
    "<a id='1-environment-setup'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "install-deps",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install required packages (run once)\n",
    "# !pip install pyspark neo4j pandas numpy matplotlib seaborn faker\n",
    "\n",
    "print(\"✅ Dependencies ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────\n",
    "#  Standard Libraries\n",
    "# ─────────────────────────────────────────────────\n",
    "import os\n",
    "import random\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import seaborn as sns\n",
    "\n",
    "# ─────────────────────────────────────────────────\n",
    "#  PySpark\n",
    "# ─────────────────────────────────────────────────\n",
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql import functions as F\n",
    "from pyspark.sql.types import (\n",
    "    StructType, StructField, IntegerType, FloatType, StringType, TimestampType\n",
    ")\n",
    "from pyspark.ml.recommendation import ALS\n",
    "from pyspark.ml.evaluation import RegressionEvaluator\n",
    "from pyspark.ml.tuning import ParamGridBuilder, CrossValidator\n",
    "\n",
    "# ─────────────────────────────────────────────────\n",
    "#  Neo4j\n",
    "# ─────────────────────────────────────────────────\n",
    "from neo4j import GraphDatabase\n",
    "\n",
    "print(\"✅ All imports successful\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "spark-init",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────\n",
    "#  Initialize Spark Session\n",
    "# ─────────────────────────────────────────────────\n",
    "spark = SparkSession.builder \\\n",
    "    .appName(\"Product-Recommendation-PySpark-Neo4j\") \\\n",
    "    .config(\"spark.driver.memory\", \"4g\") \\\n",
    "    .config(\"spark.executor.memory\", \"4g\") \\\n",
    "    .config(\"spark.sql.shuffle.partitions\", \"50\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.sparkContext.setLogLevel(\"ERROR\")\n",
    "\n",
    "print(f\"✅ Spark version: {spark.version}\")\n",
    "print(f\"✅ App Name: {spark.sparkContext.appName}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section2-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 2. Data Generation / Loading\n",
    "<a id='2-data-loading'></a>\n",
    "\n",
    "> 💡 **Note:** We simulate an e-commerce dataset (users, products, ratings/purchases).  \n",
    "> Replace with your actual dataset path if available."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "data-generation",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────\n",
    "#  Synthetic E-Commerce Dataset\n",
    "# ─────────────────────────────────────────────────\n",
    "random.seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "NUM_USERS    = 500\n",
    "NUM_PRODUCTS = 200\n",
    "NUM_RATINGS  = 8000\n",
    "\n",
    "# Product catalog\n",
    "categories = [\"Electronics\", \"Clothing\", \"Books\", \"Home & Kitchen\", \"Sports\", \"Beauty\", \"Toys\"]\n",
    "brands     = [\"BrandA\", \"BrandB\", \"BrandC\", \"BrandD\", \"BrandE\"]\n",
    "\n",
    "products_data = [\n",
    "    {\n",
    "        \"product_id\": i,\n",
    "        \"product_name\": f\"Product_{i:03d}\",\n",
    "        \"category\": random.choice(categories),\n",
    "        \"brand\": random.choice(brands),\n",
    "        \"price\": round(random.uniform(5.0, 500.0), 2)\n",
    "    }\n",
    "    for i in range(1, NUM_PRODUCTS + 1)\n",
    "]\n",
    "\n",
    "# User table\n",
    "users_data = [\n",
    "    {\n",
    "        \"user_id\": i,\n",
    "        \"age_group\": random.choice([\"18-24\", \"25-34\", \"35-44\", \"45-54\", \"55+\"]),\n",
    "        \"location\": random.choice([\"North\", \"South\", \"East\", \"West\"])\n",
    "    }\n",
    "    for i in range(1, NUM_USERS + 1)\n",
    "]\n",
    "\n",
    "# Ratings / interactions (user-product matrix)\n",
    "ratings_data = [\n",
    "    {\n",
    "        \"user_id\":    random.randint(1, NUM_USERS),\n",
    "        \"product_id\": random.randint(1, NUM_PRODUCTS),\n",
    "        \"rating\":     round(random.uniform(1.0, 5.0), 1)\n",
    "    }\n",
    "    for _ in range(NUM_RATINGS)\n",
    "]\n",
    "\n",
    "# Convert to Pandas then Spark\n",
    "pd_products = pd.DataFrame(products_data)\n",
    "pd_users    = pd.DataFrame(users_data)\n",
    "pd_ratings  = pd.DataFrame(ratings_data).drop_duplicates([\"user_id\", \"product_id\"])\n",
    "\n",
    "df_products = spark.createDataFrame(pd_products)\n",
    "df_users    = spark.createDataFrame(pd_users)\n",
    "df_ratings  = spark.createDataFrame(pd_ratings)\n",
    "\n",
    "print(f\"📦 Products : {df_products.count():,} rows\")\n",
    "print(f\"👤 Users    : {df_users.count():,} rows\")\n",
    "print(f\"⭐ Ratings  : {df_ratings.count():,} rows\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "preview-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"── Products Sample ──\")\n",
    "df_products.show(5, truncate=False)\n",
    "\n",
    "print(\"── Ratings Sample ──\")\n",
    "df_ratings.show(5)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section3-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Exploratory Data Analysis (EDA)\n",
    "<a id='3-eda'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eda-basic",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Rating Distribution ───────────────────────\n",
    "rating_pd = df_ratings.toPandas()\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 4))\n",
    "\n",
    "# 1. Rating histogram\n",
    "axes[0].hist(rating_pd['rating'], bins=20, color='steelblue', edgecolor='white')\n",
    "axes[0].set_title('Rating Distribution', fontsize=13, fontweight='bold')\n",

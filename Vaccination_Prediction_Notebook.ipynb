   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sparsity",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Sparsity Calculation ──────────────────────\n",
    "total_possible = NUM_USERS * NUM_PRODUCTS\n",
    "actual_ratings = df_ratings.count()\n",
    "sparsity = 1 - (actual_ratings / total_possible)\n",
    "\n",
    "print(f\"📊 Total possible interactions : {total_possible:,}\")\n",
    "print(f\"📊 Actual ratings              : {actual_ratings:,}\")\n",
    "print(f\"📊 Matrix Sparsity             : {sparsity:.2%}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section4-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. PySpark Data Preprocessing\n",
    "<a id='4-preprocessing'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "preprocessing",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Cast columns to correct types ─────────────\n",
    "df_ratings = df_ratings \\\n",
    "    .withColumn(\"user_id\",    F.col(\"user_id\").cast(IntegerType())) \\\n",
    "    .withColumn(\"product_id\", F.col(\"product_id\").cast(IntegerType())) \\\n",
    "    .withColumn(\"rating\",     F.col(\"rating\").cast(FloatType()))\n",
    "\n",
    "# ─── Remove any nulls ──────────────────────────\n",
    "df_ratings = df_ratings.dropna()\n",
    "\n",
    "# ─── Train / Test Split (80/20) ────────────────\n",
    "df_train, df_test = df_ratings.randomSplit([0.8, 0.2], seed=42)\n",
    "\n",
    "print(f\"🔵 Training set : {df_train.count():,} rows\")\n",
    "print(f\"🟠 Test set     : {df_test.count():,} rows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section5-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. ALS Collaborative Filtering Model\n",
    "<a id='5-als-model'></a>\n",
    "\n",
    "> **ALS (Alternating Least Squares)** factorizes the user-item matrix into two lower-rank matrices — one for users and one for items — and learns latent factors representing their preferences."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "als-train",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── ALS Model Definition ──────────────────────\n",
    "als = ALS(\n",
    "    userCol       = \"user_id\",\n",
    "    itemCol       = \"product_id\",\n",
    "    ratingCol     = \"rating\",\n",
    "    rank          = 10,       # Number of latent factors\n",
    "    maxIter       = 15,\n",
    "    regParam      = 0.1,\n",
    "    coldStartStrategy = \"drop\",\n",
    "    nonnegative   = True,\n",
    "    implicitPrefs = False\n",
    ")\n",
    "\n",
    "print(\"⚙️  Training ALS model...\")\n",
    "als_model = als.fit(df_train)\n",
    "print(\"✅ ALS model trained successfully!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "als-hypertuning",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Hyperparameter Tuning with Cross-Validation ─\n",
    "param_grid = ParamGridBuilder() \\\n",
    "    .addGrid(als.rank,     [5, 10, 15]) \\\n",
    "    .addGrid(als.regParam, [0.01, 0.1, 0.5]) \\\n",
    "    .build()\n",
    "\n",
    "evaluator = RegressionEvaluator(\n",
    "    metricName  = \"rmse\",\n",
    "    labelCol    = \"rating\",\n",
    "    predictionCol = \"prediction\"\n",
    ")\n",
    "\n",
    "cross_val = CrossValidator(\n",
    "    estimator          = als,\n",
    "    estimatorParamMaps = param_grid,\n",
    "    evaluator          = evaluator,\n",
    "    numFolds           = 3,\n",
    "    seed               = 42\n",
    ")\n",
    "\n",
    "print(\"⚙️  Running Cross-Validation (this may take a moment)...\")\n",
    "cv_model = cross_val.fit(df_train)\n",
    "best_model = cv_model.bestModel\n",
    "\n",
    "print(f\"✅ Best rank     : {best_model.rank}\")\n",
    "print(f\"✅ Best regParam : {best_model._java_obj.parent().getRegParam()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section6-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 6. Model Evaluation\n",
    "<a id='6-evaluation'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "evaluate",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Evaluate on Test Set ──────────────────────\n",
    "predictions = best_model.transform(df_test)\n",
    "predictions = predictions.dropna(subset=[\"prediction\"])\n",
    "\n",
    "rmse = evaluator.evaluate(predictions)\n",
    "\n",
    "mae_evaluator = RegressionEvaluator(\n",
    "    metricName=\"mae\", labelCol=\"rating\", predictionCol=\"prediction\"\n",
    ")\n",
    "mae = mae_evaluator.evaluate(predictions)\n",
    "\n",
    "r2_evaluator = RegressionEvaluator(\n",
    "    metricName=\"r2\", labelCol=\"rating\", predictionCol=\"prediction\"\n",
    ")\n",
    "r2 = r2_evaluator.evaluate(predictions)\n",
    "\n",
    "print(\"\\n\" + \"═\" * 40)\n",
    "print(\"  Model Evaluation Metrics\")\n",
    "print(\"═\" * 40)\n",
    "print(f\"  RMSE : {rmse:.4f}\")\n",
    "print(f\"  MAE  : {mae:.4f}\")\n",
    "print(f\"  R²   : {r2:.4f}\")\n",
    "print(\"═\" * 40)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval-viz",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Actual vs Predicted Plot ──────────────────\n",
    "pred_pd = predictions.select(\"rating\", \"prediction\").toPandas().head(300)\n",
    "\n",
    "plt.figure(figsize=(7, 5))\n",
    "plt.scatter(pred_pd['rating'], pred_pd['prediction'], alpha=0.4, color='steelblue', s=20)\n",
    "plt.plot([1, 5], [1, 5], 'r--', label='Perfect Prediction')\n",
    "plt.xlabel('Actual Rating', fontsize=12)\n",
    "plt.ylabel('Predicted Rating', fontsize=12)\n",
    "plt.title('ALS — Actual vs Predicted Ratings', fontsize=13, fontweight='bold')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "top-recommendations",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Top-10 Product Recommendations per User ───\n",
    "user_recs = best_model.recommendForAllUsers(10)\n",
    "print(\"📋 Sample recommendations for 5 users:\")\n",
    "user_recs.show(5, truncate=False)\n",
    "\n",
    "# ─── Top-10 Users per Product ──────────────────\n",
    "product_recs = best_model.recommendForAllItems(10)\n",
    "print(\"📋 Top 10 potential buyers per product (sample):\")\n",
    "product_recs.show(5, truncate=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "single-user-rec",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Recommendations for a Specific User ───────\n",
    "TARGET_USER = 42\n",
    "\n",
    "user_df = spark.createDataFrame([(TARGET_USER,)], [\"user_id\"])\n",
    "recs    = best_model.recommendForUserSubset(user_df, 10)\n",
    "\n",
    "# Explode recommendations\n",
    "recs_exploded = recs.select(\n",
    "    F.col(\"user_id\"),\n",
    "    F.explode(F.col(\"recommendations\")).alias(\"rec\")\n",
    ").select(\n",
    "    \"user_id\",\n",
    "    F.col(\"rec.product_id\").alias(\"product_id\"),\n",
    "    F.col(\"rec.rating\").alias(\"predicted_rating\")\n",
    ")\n",
    "\n",
    "# Join with product details\n",
    "recs_with_details = recs_exploded.join(\n",
    "    df_products.select(\"product_id\", \"product_name\", \"category\", \"brand\", \"price\"),\n",
    "    on=\"product_id\"\n",
    ").orderBy(F.desc(\"predicted_rating\"))\n",
    "\n",
    "print(f\"\\n🎯 Top-10 Recommendations for User {TARGET_USER}:\")\n",
    "recs_with_details.show(10, truncate=False)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section7-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 7. Neo4j — Graph Setup & Data Ingestion\n",
    "<a id='7-neo4j-setup'></a>\n",
    "\n",
    "### Graph Schema\n",
    "```\n",
    "(:User {user_id, age_group, location})\n",
    "    -[:RATED {rating}]->\n",
    "(:Product {product_id, product_name, category, brand, price})\n",
    "    -[:BELONGS_TO]->\n",
    "(:Category {name})\n",
    "    \n",
    "(:Product)-[:MADE_BY]->(:Brand {name})\n",
    "```\n",
    "\n",
    "> ⚠️ **Prerequisites:** Neo4j running on `bolt://localhost:7687`  \n",
    "> Update `NEO4J_URI`, `NEO4J_USER`, `NEO4J_PASSWORD` below."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "neo4j-config",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Neo4j Connection Config ───────────────────\n",
    "NEO4J_URI      = os.getenv(\"NEO4J_URI\",      \"bolt://localhost:7687\")\n",
    "NEO4J_USER     = os.getenv(\"NEO4J_USER\",     \"neo4j\")\n",
    "NEO4J_PASSWORD = os.getenv(\"NEO4J_PASSWORD\", \"password\")\n",
    "\n",
    "try:\n",
    "    driver = GraphDatabase.driver(NEO4J_URI, auth=(NEO4J_USER, NEO4J_PASSWORD))\n",
    "    driver.verify_connectivity()\n",
    "    print(\"✅ Connected to Neo4j successfully!\")\n",
    "except Exception as e:\n",
    "    print(f\"⚠️  Neo4j not available: {e}\")\n",
    "    print(\"   → Cypher queries are shown for reference. Skipping live execution.\")\n",
    "    driver = None"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "neo4j-helper",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Helper: Run Cypher ────────────────────────\n",
    "def run_cypher(query, params=None):\n",
    "    \"\"\"Execute a Cypher query and return results as list of dicts.\"\"\"\n",
    "    if driver is None:\n",
    "        print(f\"[SKIPPED — Neo4j offline]\\nQuery:\\n{query}\")\n",
    "        return []\n",
    "    with driver.session() as session:\n",
    "        result = session.run(query, params or {})\n",
    "        return [dict(r) for r in result]\n",
    "\n",
    "print(\"✅ Cypher helper ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "neo4j-constraints",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Create Constraints & Indexes ─────────────\n",
    "constraints = [\n",
    "    \"CREATE CONSTRAINT IF NOT EXISTS FOR (u:User)     REQUIRE u.user_id    IS UNIQUE\",\n",
    "    \"CREATE CONSTRAINT IF NOT EXISTS FOR (p:Product)  REQUIRE p.product_id IS UNIQUE\",\n",
    "    \"CREATE CONSTRAINT IF NOT EXISTS FOR (c:Category) REQUIRE c.name       IS UNIQUE\",\n",
    "    \"CREATE CONSTRAINT IF NOT EXISTS FOR (b:Brand)    REQUIRE b.name       IS UNIQUE\",\n",
    "]\n",
    "\n",
    "for q in constraints:\n",
    "    run_cypher(q)\n",
    "\n",
    "print(\"✅ Constraints and indexes created\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "neo4j-ingest",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Ingest Users into Neo4j ──────────────────\n",
    "def ingest_users(users: list):\n",
    "    query = \"\"\"\n",
    "    UNWIND $users AS u\n",
    "    MERGE (user:User {user_id: u.user_id})\n",
    "      SET user.age_group = u.age_group,\n",
    "          user.location  = u.location\n",
    "    \"\"\"\n",
    "    run_cypher(query, {\"users\": users})\n",
    "\n",
    "# ─── Ingest Products into Neo4j ───────────────\n",
    "def ingest_products(products: list):\n",
    "    query = \"\"\"\n",
    "    UNWIND $products AS p\n",
    "    MERGE (prod:Product {product_id: p.product_id})\n",
    "      SET prod.product_name = p.product_name,\n",
    "          prod.price        = p.price\n",
    "    MERGE (cat:Category  {name: p.category})\n",
    "    MERGE (brd:Brand     {name: p.brand})\n",
    "    MERGE (prod)-[:BELONGS_TO]->(cat)\n",
    "    MERGE (prod)-[:MADE_BY]->(brd)\n",
    "    \"\"\"\n",
    "    run_cypher(query, {\"products\": products})\n",
    "\n",
    "# ─── Ingest Ratings (relationships) ──────────\n",
    "def ingest_ratings(ratings: list):\n",
    "    query = \"\"\"\n",
    "    UNWIND $ratings AS r\n",
    "    MATCH (u:User    {user_id:    r.user_id})\n",
    "    MATCH (p:Product {product_id: r.product_id})\n",
    "    MERGE (u)-[rel:RATED]->(p)\n",
    "      SET rel.rating = r.rating\n",
    "    \"\"\"\n",
    "    run_cypher(query, {\"ratings\": ratings})\n",
    "\n",
    "\n",
    "# ─── Run ingestion in batches ─────────────────\n",
    "BATCH_SIZE = 100\n",
    "\n",
    "users_list    = pd_users.to_dict(\"records\")\n",
    "products_list = pd_products.to_dict(\"records\")\n",
    "ratings_list  = pd_ratings.to_dict(\"records\")\n",
    "\n",
    "for i in range(0, len(users_list), BATCH_SIZE):\n",
    "    ingest_users(users_list[i:i+BATCH_SIZE])\n",
    "\n",
    "for i in range(0, len(products_list), BATCH_SIZE):\n",
    "    ingest_products(products_list[i:i+BATCH_SIZE])\n",
    "\n",
    "for i in range(0, len(ratings_list), BATCH_SIZE):\n",
    "    ingest_ratings(ratings_list[i:i+BATCH_SIZE])\n",
    "\n",
    "print(\"✅ All data ingested into Neo4j graph!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "neo4j-verify",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Verify Graph Stats ───────────────────────\n",
    "stats_query = \"\"\"\n",
    "MATCH (u:User) WITH count(u) AS users\n",
    "MATCH (p:Product) WITH users, count(p) AS products\n",
    "MATCH ()-[r:RATED]->() WITH users, products, count(r) AS ratings\n",
    "RETURN users, products, ratings\n",
    "\"\"\"\n",
    "stats = run_cypher(stats_query)\n",
    "if stats:\n",
    "    print(f\"✅ Graph stats: {stats[0]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section8-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 8. Graph-Based Recommendations (Cypher Queries)\n",
    "<a id='8-graph-recommendations'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "graph-rec-1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Query 1: Collaborative Filtering via Graph ─\n",
    "# \"Users who bought what you bought also bought...\"\n",
    "\n",
    "collab_query = \"\"\"\n",
    "MATCH (target:User {user_id: $user_id})-[:RATED]->(p:Product)<-[:RATED]-(similar:User)\n",
    "WHERE target <> similar\n",
    "MATCH (similar)-[r:RATED]->(rec:Product)\n",
    "WHERE NOT (target)-[:RATED]->(rec)\n",
    "  AND r.rating >= 4.0\n",
    "RETURN rec.product_id   AS product_id,\n",
    "       rec.product_name AS product_name,\n",
    "       count(similar)   AS frequency,\n",
    "       avg(r.rating)    AS avg_rating\n",
    "ORDER BY frequency DESC, avg_rating DESC\n",
    "LIMIT 10\n",
    "\"\"\"\n",
    "\n",
    "print(f\"\\n🔗 Graph Collaborative Filtering for User {TARGET_USER}:\")\n",
    "results = run_cypher(collab_query, {\"user_id\": TARGET_USER})\n",
    "if results:\n",
    "    print(pd.DataFrame(results).to_string(index=False))\n",
    "else:\n",
    "    print(\"   (Neo4j offline — query shown for reference)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "graph-rec-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Query 2: Category-Based Recommendations ──\n",
    "# Recommend top-rated products in categories the user likes\n",
    "\n",
    "category_query = \"\"\"\n",
    "MATCH (u:User {user_id: $user_id})-[r:RATED]->(p:Product)-[:BELONGS_TO]->(c:Category)\n",
    "WHERE r.rating >= 4.0\n",
    "WITH c, count(p) AS category_affinity\n",
    "ORDER BY category_affinity DESC\n",
    "LIMIT 3\n",
    "MATCH (c)<-[:BELONGS_TO]-(rec:Product)\n",
    "WHERE NOT EXISTS {\n",
    "    MATCH (:User {user_id: $user_id})-[:RATED]->(rec)\n",
    "}\n",
    "MATCH ()<-[all_r:RATED]-(rec)\n",
    "WITH rec, c.name AS category, avg(all_r.rating) AS avg_rating, count(all_r) AS review_count\n",
    "WHERE review_count >= 5\n",
    "RETURN rec.product_id   AS product_id,\n",
    "       rec.product_name AS product_name,\n",
    "       category,\n",
    "       round(avg_rating, 2) AS avg_rating,\n",
    "       review_count\n",
    "ORDER BY avg_rating DESC, review_count DESC\n",
    "LIMIT 10\n",
    "\"\"\"\n",
    "\n",
    "print(f\"\\n📂 Category-Based Recommendations for User {TARGET_USER}:\")\n",
    "results2 = run_cypher(category_query, {\"user_id\": TARGET_USER})\n",
    "if results2:\n",
    "    print(pd.DataFrame(results2).to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "graph-rec-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Query 3: Trending Products (most rated this week) ─\n",
    "\n",
    "trending_query = \"\"\"\n",
    "MATCH (p:Product)<-[r:RATED]-()\n",
    "WITH p, count(r) AS total_ratings, avg(r.rating) AS avg_rating\n",
    "WHERE total_ratings >= 3\n",
    "RETURN p.product_id   AS product_id,\n",
    "       p.product_name AS product_name,\n",
    "       total_ratings,\n",
    "       round(avg_rating, 2) AS avg_rating\n",
    "ORDER BY total_ratings DESC\n",
    "LIMIT 10\n",
    "\"\"\"\n",
    "\n",
    "print(\"\\n🔥 Trending Products (Most Rated):\")\n",
    "results3 = run_cypher(trending_query)\n",
    "if results3:\n",
    "    print(pd.DataFrame(results3).to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "graph-rec-4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Query 4: Similar Users (Jaccard Similarity) ─\n",
    "\n",
    "similar_users_query = \"\"\"\n",
    "MATCH (u1:User {user_id: $user_id})-[:RATED]->(p:Product)<-[:RATED]-(u2:User)\n",
    "WHERE u1 <> u2\n",
    "WITH u1, u2, count(p) AS shared_products\n",
    "MATCH (u1)-[:RATED]->(all1:Product)\n",
    "WITH u1, u2, shared_products, count(all1) AS total_u1\n",
    "MATCH (u2)-[:RATED]->(all2:Product)\n",
    "WITH u2, shared_products, total_u1, count(all2) AS total_u2\n",
    "WITH u2,\n",
    "     shared_products,\n",
    "     toFloat(shared_products) / (total_u1 + total_u2 - shared_products) AS jaccard\n",
    "ORDER BY jaccard DESC\n",
    "LIMIT 5\n",
    "RETURN u2.user_id AS similar_user_id, shared_products, round(jaccard, 3) AS jaccard_similarity\n",
    "\"\"\"\n",
    "\n",
    "print(f\"\\n👥 Most Similar Users to User {TARGET_USER} (Jaccard Similarity):\")\n",
    "results4 = run_cypher(similar_users_query, {\"user_id\": TARGET_USER})\n",
    "if results4:\n",
    "    print(pd.DataFrame(results4).to_string(index=False))"
   ]
  },
